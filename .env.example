# ============================================================
# Navigator — env vars
# Copy to .env.local and fill in. .env.local is gitignored.
# ============================================================

# --- Supabase (client-safe) ----------------------------------
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# --- ElectricSQL sync (client-safe) --------------------------
NEXT_PUBLIC_ELECTRIC_URL="http://localhost:5133"

# --- Supabase service role (server-only — DO NOT LEAK) -------
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- AI providers (server-only — used in Edge Functions) -----
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."

# --- Email — Resend (server-only) ----------------------------
# Used for waitlist confirmations + (via Supabase SMTP) passwordless login
# emails. Leave unset to run without email — signup still succeeds locally.
RESEND_API_KEY="re_..."
WAITLIST_FROM="Navigator <hello@navigator.app>"

# Passwordless login emails (magic link + 6-digit code) are sent by Supabase
# Auth. Point Supabase's SMTP settings at Resend so they come from your domain:
#   host: smtp.resend.com  port: 465  user: resend  pass: <RESEND_API_KEY>
# (Configure under Supabase Dashboard → Auth → SMTP, or in supabase/config.toml.)

# --- Analytics (marketing surface only) ----------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="navigator.app"
