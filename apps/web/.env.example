# ============================================================
# Navigator — environment variables
# Copy to .env.local and fill in real values. .env.local is gitignored.
# The app runs in local-only mode when Supabase vars are left blank.
# ============================================================

# ── Supabase (required for auth + sync; app runs in local mode without these) ──
# Find these at: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Electric Sync (deferred — leave blank for now) ──
# Uncomment when Electric sync is wired in Phase 2.
# NEXT_PUBLIC_ELECTRIC_URL=

# ── Supabase Service Role (server-side only — waitlist DB writes) ──
# Find at: Supabase Dashboard → Settings → API → service_role key
# WARNING: Never expose this in client code or NEXT_PUBLIC_* vars.
# This key bypasses RLS and must only be used in Server Actions / API routes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Resend (for waitlist confirmation emails; optional) ──
# Without this, waitlist signup logs to console and no email is sent.
RESEND_API_KEY=re_xxxxxxxx
WAITLIST_FROM=Navigator <hello@yourdomain.com>

# ── Analytics (marketing surface only — cookieless Plausible) ──
# Leave blank to disable analytics.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=navigator.app

# ── AI features (set in Supabase Edge Function secrets, NOT here) ──
# These keys must never appear in NEXT_PUBLIC_* vars or client bundles.
# Set them via the Supabase CLI after deploying the Edge Functions:
#
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#   supabase secrets set OPENAI_API_KEY=sk-...
#
# Optionally lock the CORS allowed origin for Edge Functions:
#   supabase secrets set ALLOWED_ORIGIN=https://your-vercel-deployment.vercel.app
